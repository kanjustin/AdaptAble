# VoiceVision Environment Variables
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Required: Google AI Studio API key (free tier)
# Get one at https://aistudio.google.com/apikey — no credit card required
# Model used: gemini-2.5-flash
# Free tier: 1,500 requests/day, 15 requests/min — more than enough for demo
GEMINI_API_KEY=AIza-your-key-here
