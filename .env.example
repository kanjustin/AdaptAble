# AdaptAble Environment Variables
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Required ONLY for the AI fallback (ambiguous phrasing). Common commands work
# locally with no key and no network.
# Get one at https://aistudio.google.com/apikey — no credit card required.
# Model used: gemini-flash-lite-latest (fast, low-cost, always-current alias).
# This key stays SERVER-SIDE (used only in src/app/api/interpret/route.ts). Never
# put it in client code, the extension, or git.
GEMINI_API_KEY=AIza-your-key-here
