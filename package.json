    "eval": "node evals/run.mjs",
    "eval:api": "node evals/run.mjs --api",
    "build:icons": "node scripts/build-icons.mjs",
    "build:demo": "node scripts/build-demo.mjs",
    "build:playground": "node scripts/build-playground.mjs",
    "build:pages": "node scripts/build-demo.mjs && node scripts/build-playground.mjs",
    "pack:comis": "cd comis && zip -r -FS ../comis.zip . -x '.*'"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "next": "16.2.7",
    "react": "19.2.4",
